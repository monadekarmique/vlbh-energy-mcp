# ── Make.com webhooks ──────────────────────────────────────────────────
# Webhook URL du scénario Make qui écrit dans svlbh-v2 (ID 155674)
MAKE_WEBHOOK_PUSH_URL=https://hook.eu2.make.com/REPLACE_PUSH_WEBHOOK_ID

# Webhook URL du scénario Make qui lit depuis svlbh-v2 par sessionKey
MAKE_WEBHOOK_PULL_URL=https://hook.eu2.make.com/REPLACE_PULL_WEBHOOK_ID

# ── Auth ────────────────────────────────────────────────────────────────
# Token passé dans le header X-VLBH-Token par les clients iOS/Android
VLBH_TOKEN=REPLACE_WITH_STRONG_SECRET

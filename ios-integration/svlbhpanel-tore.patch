+                stZones = Double(st.zonesAtteintes ?? 0)
+                stProfondeur = Double(st.profondeur ?? 0)
+                stRevasc = Double(st.revascularisation ?? 0)
+                stDecompaction = Double(st.decompaction ?? 0)
+            }
+        }
+    }
+}
